// Tinies - Pet services marketplace & rescue adoption (Cyprus)
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  owner
  provider
  rescue
  adopter
  admin
}

enum ServiceType {
  walking
  sitting
  boarding
  drop_in
  daycare
}

enum BookingStatus {
  pending
  accepted
  declined
  active
  completed
  cancelled
}

enum CancellationPolicy {
  flexible
  moderate
  strict
}

enum ClaimType {
  pet_injury
  property_damage
  provider_no_show
  owner_no_show
}

enum DisputeType {
  service_quality
  pet_welfare
  communication
  payment
}

enum DisputeRuling {
  no_action
  warning
  partial_refund
  full_refund
  provider_suspended
  owner_restricted
}

enum AdoptionListingStatus {
  available
  application_pending
  matched
  in_transit
  adopted
  memorial
}

enum ApplicationStatus {
  new
  under_review
  approved
  declined
  withdrawn
}

enum PlacementStatus {
  preparing
  vet_complete
  transport_booked
  in_transit
  delivered
  follow_up
  completed
}

enum PayoutStatus {
  pending
  processing
  completed
  failed
}

enum DonationSource {
  roundup
  signup
  one_time
  guardian
  platform_commission
  campaign
}

enum GuardianTier {
  friend
  guardian
  champion
  custom
}

enum GuardianStatus {
  active
  paused
  cancelled
}

enum MeetAndGreetStatus {
  requested
  confirmed
  completed
  cancelled
  expired
}

enum LocationType {
  owner_home
  provider_home
  neutral
  video
}

enum RecurringBookingStatus {
  pending_setup
  active
  paused
  cancelled
}

// ---------------------------------------------------------------------------
// Users & profiles
// ---------------------------------------------------------------------------

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  phone             String?
  passwordHash      String    @map("password_hash")
  name              String
  role              UserRole
  country           String?
  district          String?
  avatarUrl         String?   @map("avatar_url")
  emailVerified     Boolean   @default(false) @map("email_verified")
  phoneVerified     Boolean   @default(false) @map("phone_verified")
  languagePreference String?  @map("language_preference")
  totalDonated      Float?    @map("total_donated")
  stripeCustomerId  String?   @unique @map("stripe_customer_id")
  /** Exclusive end (UTC) of the donation month window last covered by a monthly giving summary email. */
  givingSummaryPeriodEndSent DateTime? @map("giving_summary_period_end_sent")
  /** Set after the post-signup /welcome donation prompt is skipped or completed; null means show /welcome after login. */
  welcomeFlowCompletedAt DateTime? @map("welcome_flow_completed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  petsAsOwner           Pet[]
  providerProfile       ProviderProfile?
  bookingsAsOwner       Booking[]           @relation("BookingOwner")
  bookingsAsProvider    Booking[]           @relation("BookingProvider")
  reviewsWritten       Review[]            @relation("ReviewReviewer")
  messagesSent         Message[]            @relation("MessageSender")
  messagesReceived     Message[]            @relation("MessageRecipient")
  rescueOrg            RescueOrg?
  adoptionApplications AdoptionApplication[]
  placementsAsAdopter  AdoptionPlacement[]
  donations            Donation[]
  guardianSubscriptions GuardianSubscription[]
  givingPreferences    UserGivingPreference?
  guaranteeClaimsReported GuaranteeClaim[]  @relation("GuaranteeClaimReporter")
  guaranteeClaimsAdmin GuaranteeClaim[]     @relation("GuaranteeClaimAdmin")
  guaranteeClaimsPayoutRecipient GuaranteeClaim[] @relation("GuaranteeClaimPayoutRecipient")
  disputesOpened       Dispute[]            @relation("DisputeOpenedBy")
  disputesAsRespondent  Dispute[]            @relation("DisputeRespondent")
  disputesAdmin        Dispute[]            @relation("DisputeAdmin")
  meetAndGreetsAsOwner MeetAndGreet[]       @relation("MeetAndGreetOwner")
  meetAndGreetsAsProvider MeetAndGreet[]    @relation("MeetAndGreetProvider")
  givingDistributionsApproved GivingFundDistribution[]
  charity Charity?
  providerFavoritesAsOwner   ProviderFavorite[] @relation("ProviderFavoriteOwner")
  providerFavoritesAsTarget  ProviderFavorite[] @relation("ProviderFavoriteProvider")
  bookingUpdatesSent         BookingUpdate[]    @relation("BookingUpdateProvider")
  providerCertifications     ProviderCertification[]
  feedbackSubmissions        Feedback[]
  tiniesCardsAsProvider      TiniesCard[] @relation("TiniesCardProvider")
  tiniesCardsAsOwner         TiniesCard[] @relation("TiniesCardOwner")
  recurringBookingsAsOwner   RecurringBooking[] @relation("RecurringBookingOwner")
  recurringBookingsAsProvider RecurringBooking[] @relation("RecurringBookingProvider")

  @@index([email])
  @@index([role])
  @@index([district])
  @@map("users")
}

model Feedback {
  id            String   @id @default(uuid())
  userId        String?  @map("user_id")
  type          String
  description   String   @db.Text
  email         String?
  pageUrl       String   @map("page_url")
  userAgent     String?  @map("user_agent") @db.Text
  screenshotUrl String? @map("screenshot_url")
  status        String   @default("new")
  adminNotes    String?  @map("admin_notes") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([type])
  @@index([createdAt(sort: Desc)])
  @@map("feedback")
}

model Pet {
  id              String   @id @default(uuid())
  ownerId         String   @map("owner_id")
  name            String
  species         String   // dog | cat | other
  breed           String?
  ageYears        Float?   @map("age_years")
  weightKg        Float?   @map("weight_kg")
  sex             String?
  spayedNeutered  Boolean? @map("spayed_neutered")
  temperament     String?
  medicalNotes    String?  @map("medical_notes")
  dietaryNeeds    String?  @map("dietary_needs")
  vetName         String?  @map("vet_name")
  vetPhone        String?  @map("vet_phone")
  photos          String[]
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@map("pets")
}

model ProviderProfile {
  id                   String    @id @default(uuid())
  userId               String    @unique @map("user_id")
  bio                  String?
  yearsExperience      Int?      @map("years_experience")
  servicesOffered      Json      @map("services_offered") // [{ type, base_price, additional_pet_price, price_unit, max_pets }]
  serviceAreaLat       Float?    @map("service_area_lat")
  serviceAreaLng       Float?    @map("service_area_lng")
  serviceAreaRadiusKm  Float?    @map("service_area_radius_km")
  maxPets              Int?      @map("max_pets")
  petTypesAccepted    String?   @map("pet_types_accepted")
  availability        Json?     @map("availability") // weekly schedule
  idDocumentUrl        String?   @map("id_document_url")
  stripeVerificationSessionId String? @map("stripe_verification_session_id")
  verified             Boolean   @default(false)
  verifiedAt           DateTime? @map("verified_at")
  responseRate         Float?    @map("response_rate")
  avgRating            Float?    @map("avg_rating")
  reviewCount         Int       @default(0) @map("review_count")
  cancellationPolicy   CancellationPolicy @default(flexible) @map("cancellation_policy")
  cancellationRate     Float?    @map("cancellation_rate")
  photos              String[]
  stripeConnectAccountId String? @map("stripe_connect_account_id")
  slug                String    @unique
  homeType            String?   @map("home_type")       // house | apartment
  hasYard             Boolean?  @map("has_yard")
  yardFenced          Boolean?  @map("yard_fenced")
  smokingHome         Boolean?  @map("smoking_home")
  petsInHome          String?   @map("pets_in_home")
  childrenInHome      String?   @map("children_in_home")
  dogsOnFurniture     Boolean?  @map("dogs_on_furniture")
  pottyBreakFrequency String?   @map("potty_break_frequency")
  typicalDay          String?   @map("typical_day")
  infoWantedAboutPet  String?   @map("info_wanted_about_pet")
  repeatClientCount   Int      @default(0) @map("repeat_client_count")
  confirmedHolidays   String[] @default([]) @map("confirmed_holidays")
  headline             String?
  videoIntroUrl        String?   @map("video_intro_url")
  experienceTags       String[]  @default([]) @map("experience_tags")
  /// Array of { title, issuer?, year?, description? }
  qualifications       Json?
  languages            String[]  @default([])
  homeDescription      String?   @map("home_description") @db.Text
  homePhotos           String[]  @default([]) @map("home_photos")
  whyIDoThis           String?   @map("why_i_do_this") @db.Text
  previousExperience   String?   @map("previous_experience") @db.Text
  insuranceDetails     String?   @map("insurance_details")
  emergencyProtocol    String?   @map("emergency_protocol") @db.Text
  acceptedBreeds       String[]  @default([]) @map("accepted_breeds")
  notAccepted          String[]  @default([]) @map("not_accepted")
  responseTimeMinutes  Int?      @map("response_time_minutes")
  /// Percentage 0–100; updated when repeat client stats refresh
  repeatClientRate     Float?    @map("repeat_client_rate")
  backgroundCheckPassed Boolean  @default(false) @map("background_check_passed")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews  Review[]
  payouts  Payout[]

  @@index([userId])
  @@index([verified])
  @@index([slug])
  @@index([serviceAreaLat, serviceAreaLng])
  @@map("provider_profiles")
}

model ProviderFavorite {
  id          String   @id @default(uuid())
  ownerId     String   @map("owner_id")
  providerId  String   @map("provider_id")
  createdAt   DateTime @default(now()) @map("created_at")

  owner    User @relation("ProviderFavoriteOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  provider User @relation("ProviderFavoriteProvider", fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, providerId])
  @@index([ownerId])
  @@index([providerId])
  @@map("provider_favorites")
}

// ---------------------------------------------------------------------------
// Bookings, reviews, messages
// ---------------------------------------------------------------------------

model Booking {
  id                      String          @id @default(uuid())
  ownerId                 String          @map("owner_id")
  providerId              String          @map("provider_id")
  petIds                  String[]        @map("pet_ids")
  serviceType             ServiceType     @map("service_type")
  startDatetime           DateTime        @map("start_datetime")
  endDatetime             DateTime        @map("end_datetime")
  specialInstructions     String?         @map("special_instructions")
  status                  BookingStatus
  totalPrice              Int             @map("total_price") // cents
  commissionAmount        Int             @map("commission_amount") // cents
  priceBreakdown          Json?           @map("price_breakdown")
  stripePaymentIntentId   String?         @map("stripe_payment_intent_id")
  cancelledAt             DateTime?       @map("cancelled_at")
  cancelledBy             String?         @map("cancelled_by") // user id
  cancellationReason     String?         @map("cancellation_reason")
  refundAmount            Int?            @map("refund_amount") // cents
  refundStripeId          String?         @map("refund_stripe_id")
  refundStatus            String?         @map("refund_status")
  hasGuaranteeClaim       Boolean         @default(false) @map("has_guarantee_claim")
  hasDispute              Boolean         @default(false) @map("has_dispute")
  walkStartedAt           DateTime?       @map("walk_started_at")
  walkEndedAt             DateTime?       @map("walk_ended_at")
  walkRoute               Json?           @map("walk_route") // [{ lat, lng, timestamp }]
  walkDistanceKm          Float?          @map("walk_distance_km")
  walkDurationMinutes    Int?            @map("walk_duration_minutes")
  walkSummaryMapUrl       String?         @map("walk_summary_map_url")
  walkActivities         Json?           @map("walk_activities") // [{ type: "pee"|"poo"|"food"|"water", lat, lng, timestamp }]
  serviceReport         Json?           @map("service_report")   // { arrivalTime, departureTime, notes, photos[], activities[], submittedAt }
  tipAmountCents        Int?            @map("tip_amount") // cents; legacy column name
  tipStripePaymentIntentId String?       @map("tip_stripe_payment_intent_id")
  tipPaidAt             DateTime?       @map("tip_paid_at")
  reminder24hSentAt     DateTime?       @map("reminder_24h_sent_at")
  reviewPromptSentAt    DateTime?       @map("review_prompt_sent_at")
  recurringBookingId    String?         @map("recurring_booking_id")
  createdAt               DateTime        @default(now()) @map("created_at")
  updatedAt               DateTime        @updatedAt @map("updated_at")

  owner    User    @relation("BookingOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  provider User    @relation("BookingProvider", fields: [providerId], references: [id], onDelete: Restrict)
  recurringBooking RecurringBooking? @relation(fields: [recurringBookingId], references: [id], onDelete: SetNull)
  reviews  Review[]
  messages Message[]
  guaranteeClaims GuaranteeClaim[]
  disputes Dispute[]
  meetAndGreets MeetAndGreet[]
  donations Donation[]
  updates       BookingUpdate[]
  tiniesCard    TiniesCard?

  @@index([ownerId])
  @@index([providerId])
  @@index([status])
  @@index([startDatetime])
  @@index([createdAt])
  @@index([recurringBookingId])
  @@map("bookings")
}

/// Weekly repeat arrangement; first session is a normal Booking until provider accepts.
model RecurringBooking {
  id                     String                 @id @default(uuid())
  ownerId                String                 @map("owner_id")
  providerId             String                 @map("provider_id")
  petIds                 String[]               @map("pet_ids")
  serviceType            ServiceType            @map("service_type")
  /// 0 = Sunday … 6 = Saturday (JavaScript convention)
  daysOfWeek             Int[]                  @map("days_of_week")
  timeSlot               String                 @map("time_slot")
  durationMinutes        Int?                   @map("duration_minutes")
  specialInstructions    String?                @map("special_instructions")
  pricePerSessionCents   Int                    @map("price_per_session_cents")
  additionalPetCount     Int                    @default(0) @map("additional_pet_count")
  status                 RecurringBookingStatus
  startDate              DateTime               @map("start_date")
  endDate                DateTime?              @map("end_date")
  nextBookingDate        DateTime?              @map("next_booking_date")
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")

  owner    User     @relation("RecurringBookingOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  provider User     @relation("RecurringBookingProvider", fields: [providerId], references: [id], onDelete: Restrict)
  bookings Booking[]

  @@index([ownerId])
  @@index([providerId])
  @@index([status, nextBookingDate])
  @@map("recurring_bookings")
}

/// Post-service activity report (Tinies Card) — one per completed booking.
model TiniesCard {
  id                String      @id @default(uuid())
  bookingId         String      @unique @map("booking_id")
  providerId        String      @map("provider_id")
  ownerId           String      @map("owner_id")
  petIds            String[]    @map("pet_ids")
  serviceType       ServiceType @map("service_type")
  startedAt         DateTime    @map("started_at")
  endedAt           DateTime    @map("ended_at")
  durationMinutes   Int         @map("duration_minutes")
  walkDistanceKm    Float?      @map("walk_distance_km")
  walkRouteJson     Json?       @map("walk_route_json")
  walkMapImageUrl   String?     @map("walk_map_image_url")
  activities        Json
  photos            String[]    @default([])
  personalNote      String      @map("personal_note") @db.VarChar(500)
  mood              String      @db.VarChar(32)
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider User    @relation("TiniesCardProvider", fields: [providerId], references: [id], onDelete: Restrict)
  owner    User    @relation("TiniesCardOwner", fields: [ownerId], references: [id], onDelete: Restrict)

  @@index([ownerId])
  @@index([providerId])
  @@map("tinies_cards")
}

model BookingUpdate {
  id          String   @id @default(uuid())
  bookingId   String   @map("booking_id")
  providerId  String   @map("provider_id")
  text        String?  @map("text")
  photos      String[] @default([])
  videoUrl    String?  @map("video_url")
  createdAt   DateTime @default(now()) @map("created_at")

  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider User    @relation("BookingUpdateProvider", fields: [providerId], references: [id], onDelete: Restrict)

  @@index([bookingId])
  @@index([createdAt])
  @@map("booking_updates")
}

model Review {
  id              String    @id @default(uuid())
  bookingId       String    @map("booking_id")
  reviewerId      String    @map("reviewer_id")
  providerId      String    @map("provider_id")
  rating          Int       // 1-5
  text            String
  photos          String[]
  providerResponse String?  @map("provider_response")
  responseAt      DateTime? @map("response_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  booking        Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewer       User           @relation("ReviewReviewer", fields: [reviewerId], references: [id], onDelete: Restrict)
  providerProfile ProviderProfile @relation(fields: [providerId], references: [userId], onDelete: Restrict)

  @@unique([bookingId]) // one review per booking
  @@index([bookingId])
  @@index([reviewerId])
  @@index([providerId])
  @@map("reviews")
}

model Message {
  id                    String    @id @default(uuid())
  conversationId        String    @map("conversation_id")
  senderId               String    @map("sender_id")
  recipientId            String    @map("recipient_id")
  bookingId              String?   @map("booking_id")
  adoptionApplicationId  String?   @map("adoption_application_id")
  content                String
  photos                 String[]
  readAt                 DateTime? @map("read_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  sender   User    @relation("MessageSender", fields: [senderId], references: [id], onDelete: Restrict)
  recipient User   @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Restrict)
  booking  Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  adoptionApplication AdoptionApplication? @relation(fields: [adoptionApplicationId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([senderId])
  @@index([recipientId])
  @@index([bookingId])
  @@index([adoptionApplicationId])
  @@index([createdAt])
  @@map("messages")
}

// ---------------------------------------------------------------------------
// Rescue & adoption
// ---------------------------------------------------------------------------

model RescueOrg {
  id                  String    @id @default(uuid())
  userId              String    @unique @map("user_id")
  name                String
  mission             String?
  /// Long-form about text for public profile (app layer max 2000 chars)
  description         String?   @db.Text
  foundedYear         Int?      @map("founded_year")
  /// Array of { name, role, photo?, bio? }
  teamMembers         Json?     @map("team_members")
  facilityPhotos      String[]  @default([]) @map("facility_photos")
  facilityVideoUrl    String?   @map("facility_video_url")
  operatingHours      String?   @map("operating_hours")
  volunteerInfo       String?   @map("volunteer_info")
  donationNeeds       String?   @map("donation_needs")
  totalAnimalsRescued Int?      @map("total_animals_rescued")
  totalAnimalsAdopted Int?      @map("total_animals_adopted")
  contactPhone        String?   @map("contact_phone")
  /// Public-facing contact email (separate from login email on User)
  contactEmail        String?   @map("contact_email")
  district            String?
  coverPhotoUrl       String?   @map("cover_photo_url")
  location            String?
  charityRegistration String?   @map("charity_registration")
  website             String?
  socialLinks         Json?     @map("social_links")
  logoUrl             String?   @map("logo_url")
  bankIban            String?   @map("bank_iban")
  verified            Boolean   @default(false)
  slug                String    @unique
  donationsTabLastSeenAt DateTime? @map("donations_tab_last_seen_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings  AdoptionListing[]
  placements AdoptionPlacement[]
  linkedCharity Charity?
  campaigns Campaign[]

  @@index([userId])
  @@index([verified])
  @@index([slug])
  @@map("rescue_orgs")
}

model AdoptionListing {
  id                   String    @id @default(uuid())
  orgId                String    @map("org_id")
  name                 String
  /// Other names the animal responds to
  alternateNames       String[]  @default([]) @map("alternate_names")
  /// Fun context, e.g. mistaken sex at intake
  nameStory            String?   @map("name_story")
  species              String
  breed                String?
  estimatedAge         String?   @map("estimated_age")
  sex                  String?
  spayedNeutered       Boolean?  @map("spayed_neutered")
  temperament          String?
  medicalHistory       String?   @map("medical_history")
  specialNeeds         String?   @map("special_needs")
  /// Rescue story: how they came to the sanctuary
  backstory            String?
  /// Detailed personality, quirks, habits (long-form)
  personality          String?
  /// Ideal adopter / home description
  idealHome            String?   @map("ideal_home")
  /// Compatibility tags, e.g. "other cats", "dogs"
  goodWith             String[]  @default([]) @map("good_with")
  /// Compatibility cautions, e.g. "small children"
  notGoodWith          String[]  @default([]) @map("not_good_with")
  /// YouTube or direct video URL
  videoUrl             String?   @map("video_url")
  /// Where the animal is fostered (city / area), if applicable
  fosterLocation       String?   @map("foster_location")
  localAdoptionFee     Int?      @map("local_adoption_fee") // cents
  internationalEligible Boolean  @default(false) @map("international_eligible")
  destinationCountries String[] @map("destination_countries")
  /// Public gallery; app layer caps at MAX_LISTING_PHOTOS (10)
  photos               String[]
  /// e.g. "Of Gertian"
  lineageTitle         String?   @map("lineage_title")
  motherId             String?   @map("mother_id")
  fatherId             String?   @map("father_id")
  motherName           String?   @map("mother_name")
  fatherName           String?   @map("father_name")
  /// Other listing IDs on Tinies (same-species family)
  siblingIds           String[]  @default([]) @map("sibling_ids")
  familyNotes          String?   @map("family_notes")
  status               AdoptionListingStatus
  active                Boolean   @default(true)
  slug                 String    @unique
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  org          RescueOrg @relation(fields: [orgId], references: [id], onDelete: Cascade)
  applications AdoptionApplication[]
  placements   AdoptionPlacement[]
  motherListing  AdoptionListing?  @relation("AdoptionListingMother", fields: [motherId], references: [id], onDelete: SetNull)
  fatherListing  AdoptionListing?  @relation("AdoptionListingFather", fields: [fatherId], references: [id], onDelete: SetNull)
  childrenAsMother AdoptionListing[] @relation("AdoptionListingMother")
  childrenAsFather AdoptionListing[] @relation("AdoptionListingFather")

  @@index([orgId])
  @@index([status])
  @@index([species])
  @@index([slug])
  @@index([motherId])
  @@index([fatherId])
  @@map("adoption_listings")
}

model AdoptionApplication {
  id               String            @id @default(uuid())
  listingId        String            @map("listing_id")
  applicantId      String            @map("applicant_id")
  country          String
  city             String
  livingSituation  String?           @map("living_situation")
  hasGarden        Boolean?          @map("has_garden")
  otherPets        String?           @map("other_pets")
  childrenAges     String?           @map("children_ages")
  experience       String?
  reason           String?
  vetReference     String?           @map("vet_reference")
  status           ApplicationStatus
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  listing   AdoptionListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  applicant User           @relation(fields: [applicantId], references: [id], onDelete: Restrict)
  placement AdoptionPlacement?
  messages  Message[]

  @@index([listingId])
  @@index([applicantId])
  @@index([status])
  @@map("adoption_applications")
}

model AdoptionPlacement {
  id                     String         @id @default(uuid())
  listingId              String         @map("listing_id")
  applicationId          String         @unique @map("application_id")
  rescueOrgId            String         @map("rescue_org_id")
  adopterId              String         @map("adopter_id")
  destinationCountry    String         @map("destination_country")
  vetPrepStatus          Json?          @map("vet_prep_status")
  transportMethod        String?        @map("transport_method")
  transportProviderId    String?        @map("transport_provider_id")
  transportBookedDate    DateTime?      @map("transport_booked_date")
  departureDate          DateTime?      @map("departure_date")
  arrivalDate            DateTime?      @map("arrival_date")
  totalFee               Int            @map("total_fee") // cents
  vetCost                Int?           @map("vet_cost") // cents
  transportCost          Int?           @map("transport_cost") // cents
  coordinationFee        Int?           @map("coordination_fee") // cents
  stripePaymentIntentId  String?        @map("stripe_payment_intent_id")
  status                 PlacementStatus
  checkin1w              DateTime?      @map("checkin_1w")
  checkin1m              DateTime?      @map("checkin_1m")
  checkin3m              DateTime?      @map("checkin_3m")
  successStoryText       String?        @map("success_story_text")
  successStoryPhotos     String[]       @default([]) @map("success_story_photos")
  successStoryApprovedAt DateTime?      @map("success_story_approved_at")
  /** Idempotent post-adoption marketing emails: e.g. "1w", "1m", "3m". */
  postAdoptionReminderKeys String[]    @default([]) @map("post_adoption_reminder_keys")
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")

  listing   AdoptionListing  @relation(fields: [listingId], references: [id], onDelete: Restrict)
  application AdoptionApplication @relation(fields: [applicationId], references: [id], onDelete: Restrict)
  rescueOrg  RescueOrg  @relation(fields: [rescueOrgId], references: [id], onDelete: Restrict)
  adopter   User        @relation(fields: [adopterId], references: [id], onDelete: Restrict)
  transportProvider TransportProvider? @relation(fields: [transportProviderId], references: [id], onDelete: SetNull)

  @@index([listingId])
  @@index([applicationId])
  @@index([rescueOrgId])
  @@index([adopterId])
  @@index([transportProviderId])
  @@index([status])
  @@index([successStoryApprovedAt])
  @@map("adoption_placements")
}

model Campaign {
  id                 String   @id @default(uuid())
  rescueOrgId        String   @map("rescue_org_id")
  slug               String   @unique
  title              String
  subtitle           String?
  description        String   @db.Text
  coverPhotoUrl      String?  @map("cover_photo_url")
  goalAmountCents    Int?     @map("goal_amount_cents")
  raisedAmountCents  Int      @default(0) @map("raised_amount_cents")
  donorCount         Int      @default(0) @map("donor_count")
  /// active | paused | completed | draft
  status             String   @default("draft")
  featured           Boolean  @default(false)
  milestones         Json?
  updates            Json?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  rescueOrg RescueOrg         @relation(fields: [rescueOrgId], references: [id], onDelete: Cascade)
  donations CampaignDonation[]

  @@index([rescueOrgId])
  @@index([status])
  @@index([featured])
  @@map("campaigns")
}

model CampaignDonation {
  id         String   @id @default(uuid())
  campaignId String   @map("campaign_id")
  donationId String   @unique @map("donation_id")
  donorName  String?  @map("donor_name")
  message    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donation Donation @relation(fields: [donationId], references: [id], onDelete: Restrict)

  @@index([campaignId])
  @@index([createdAt])
  @@map("campaign_donations")
}

model TransportProvider {
  id              String   @id @default(uuid())
  name            String
  type            String   // courier | cargo | volunteer
  countriesServed String[] @map("countries_served")
  contactInfo     String?  @map("contact_info")
  pricingNotes    String?  @map("pricing_notes")
  rating          Float?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  placements AdoptionPlacement[]

  @@index([active])
  @@map("transport_providers")
}

// ---------------------------------------------------------------------------
// Payouts (providers)
// ---------------------------------------------------------------------------

model Payout {
  id                String       @id @default(uuid())
  providerId        String       @map("provider_id")
  amount            Int          // cents
  commission        Int          // cents
  netAmount         Int          @map("net_amount") // cents
  stripeTransferId  String?      @map("stripe_transfer_id")
  periodStart       DateTime     @map("period_start")
  periodEnd         DateTime     @map("period_end")
  status            PayoutStatus
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  providerProfile ProviderProfile @relation(fields: [providerId], references: [userId], onDelete: Restrict)

  @@index([providerId])
  @@index([status])
  @@index([periodStart, periodEnd])
  @@map("payouts")
}

// ---------------------------------------------------------------------------
// Giving: charities, donations, guardian, distributions
// ---------------------------------------------------------------------------

model Charity {
  id                  String    @id @default(uuid())
  name                String
  registrationNumber  String?   @map("registration_number")
  mission             String?
  website             String?
  socialLinks         Json?     @map("social_links")
  logoUrl             String?   @map("logo_url")
  photos              String[]
  primaryContactName  String?   @map("primary_contact_name")
  primaryContactEmail String?   @map("primary_contact_email")
  bankIban            String?   @map("bank_iban")
  howFundsUsed        String?   @map("how_funds_used")
  verified            Boolean   @default(false)
  verifiedAt          DateTime? @map("verified_at")
  featured            Boolean   @default(false)
  featuredSince       DateTime? @map("featured_since")
  animalsInCare       Int?      @map("animals_in_care")
  district            String?
  totalReceived       Float?    @map("total_received")
  supporterCount      Int?      @map("supporter_count")
  annualUpdateText    String?   @map("annual_update_text")
  annualUpdateDate    DateTime? @map("annual_update_date")
  slug                String    @unique
  active              Boolean   @default(true)
  userId              String?   @unique @map("user_id")
  inviteToken         String?   @unique @map("invite_token")
  rescueOrgId         String?   @unique @map("rescue_org_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user                User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  rescueOrg           RescueOrg? @relation(fields: [rescueOrgId], references: [id], onDelete: SetNull)
  donations           Donation[]
  guardianSubscriptions GuardianSubscription[]
  userGivingPreferences UserGivingPreference[]

  @@index([verified])
  @@index([featured])
  @@index([slug])
  @@index([active])
  @@index([userId])
  @@index([rescueOrgId])
  @@map("charities")
}

model Donation {
  id                    String         @id @default(uuid())
  userId                String?        @map("user_id")
  charityId             String?        @map("charity_id")
  source                DonationSource
  amount                Int            // cents
  bookingId             String?        @map("booking_id")
  stripePaymentIntentId String?       @map("stripe_payment_intent_id")
  stripeInvoiceId       String?       @map("stripe_invoice_id")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  charity Charity? @relation(fields: [charityId], references: [id], onDelete: SetNull)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  campaignLink CampaignDonation?

  @@index([userId])
  @@index([charityId])
  @@index([bookingId])
  @@index([source])
  @@index([createdAt])
  @@index([bookingId, source])
  @@map("donations")
}

model GuardianSubscription {
  id                    String         @id @default(uuid())
  userId                String         @unique @map("user_id")
  charityId             String?       @map("charity_id")
  stripeSubscriptionId  String?       @unique @map("stripe_subscription_id")
  stripeCustomerId      String?       @map("stripe_customer_id")
  amountMonthly         Int            @map("amount_monthly") // cents
  tier                  GuardianTier
  status                GuardianStatus
  startedAt             DateTime?      @map("started_at")
  pausedAt              DateTime?     @map("paused_at")
  cancelledAt           DateTime?     @map("cancelled_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  charity Charity? @relation(fields: [charityId], references: [id], onDelete: SetNull)
  userGivingPreferences UserGivingPreference[]

  @@index([userId])
  @@index([charityId])
  @@index([status])
  @@map("guardian_subscriptions")
}

model UserGivingPreference {
  id                      String    @id @default(uuid())
  userId                  String    @unique @map("user_id")
  preferredCharityId      String?   @map("preferred_charity_id")
  roundupEnabled          Boolean   @default(true) @map("roundup_enabled")
  showOnLeaderboard       Boolean   @default(false) @map("show_on_leaderboard")
  guardianSubscriptionId  String?   @map("guardian_subscription_id")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  charity  Charity? @relation(fields: [preferredCharityId], references: [id], onDelete: SetNull)
  guardianSubscription GuardianSubscription? @relation(fields: [guardianSubscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([preferredCharityId])
  @@map("user_giving_preferences")
}

// ---------------------------------------------------------------------------
// Trust & safety: guarantee claims, disputes, meet-and-greets
// ---------------------------------------------------------------------------

model GuaranteeClaim {
  id                     String    @id @default(uuid())
  bookingId              String    @map("booking_id")
  reporterId             String    @map("reporter_id")
  claimType              ClaimType @map("claim_type")
  description            String
  photos                 String[]
  otherPartyResponse     String?   @map("other_party_response")
  otherPartyPhotos       String[]  @map("other_party_photos")
  adminId                String?   @map("admin_id")
  ruling                 String?   // approved full/partial/denied - free text or extend with enum later
  rulingNotes            String?   @map("ruling_notes")
  payoutAmount           Int?      @map("payout_amount") // cents
  payoutRecipientId      String?   @map("payout_recipient_id")
  payoutStripeTransferId String?   @map("payout_stripe_transfer_id")
  status                 String    // submitted | under_review | awaiting_response | resolved | appealed | appeal_resolved
  appealNotes            String?   @map("appeal_notes")
  appealRuling           String?   @map("appeal_ruling")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reporter  User    @relation("GuaranteeClaimReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  admin     User?   @relation("GuaranteeClaimAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  payoutRecipient User? @relation("GuaranteeClaimPayoutRecipient", fields: [payoutRecipientId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([reporterId])
  @@index([adminId])
  @@index([status])
  @@map("guarantee_claims")
}

model Dispute {
  id                  String        @id @default(uuid())
  bookingId           String        @map("booking_id")
  openedBy            String        @map("opened_by")
  disputeType         DisputeType   @map("dispute_type")
  description         String
  evidencePhotos      String[]      @map("evidence_photos")
  respondentId        String        @map("respondent_id")
  respondentResponse  String?       @map("respondent_response")
  respondentPhotos    String[]      @map("respondent_photos")
  adminId             String?       @map("admin_id")
  ruling              DisputeRuling?
  rulingNotes         String?       @map("ruling_notes")
  refundAmount        Int?          @map("refund_amount") // cents
  status              String        // opened | awaiting_response | under_review | resolved
  resolvedAt          DateTime?     @map("resolved_at")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  booking    Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  openedByUser User  @relation("DisputeOpenedBy", fields: [openedBy], references: [id], onDelete: Restrict)
  respondent User   @relation("DisputeRespondent", fields: [respondentId], references: [id], onDelete: Restrict)
  admin      User?   @relation("DisputeAdmin", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([openedBy])
  @@index([respondentId])
  @@index([adminId])
  @@index([status])
  @@map("disputes")
}

model MeetAndGreet {
  id                         String             @id @default(uuid())
  ownerId                    String             @map("owner_id")
  providerId                 String             @map("provider_id")
  petIds                     String[]           @map("pet_ids")
  requestedDatetime          DateTime          @map("requested_datetime")
  confirmedDatetime          DateTime?          @map("confirmed_datetime")
  locationType               LocationType       @map("location_type")
  locationNotes              String?            @map("location_notes")
  status                     MeetAndGreetStatus
  providerSuggestedDatetime  DateTime?         @map("provider_suggested_datetime")
  providerMessage            String?           @map("provider_message")
  ownerNotesAfter            String?            @map("owner_notes_after")
  providerNotesAfter         String?            @map("provider_notes_after")
  ledToBooking               Boolean            @default(false) @map("led_to_booking")
  bookingId                  String?            @map("booking_id")
  createdAt                  DateTime           @default(now()) @map("created_at")
  updatedAt                  DateTime           @updatedAt @map("updated_at")

  owner    User     @relation("MeetAndGreetOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  provider User     @relation("MeetAndGreetProvider", fields: [providerId], references: [id], onDelete: Cascade)
  booking  Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([providerId])
  @@index([bookingId])
  @@index([status])
  @@index([requestedDatetime])
  @@map("meet_and_greets")
}

// ---------------------------------------------------------------------------
// Giving fund & webhooks
// ---------------------------------------------------------------------------

model GivingFundDistribution {
  id                  String    @id @default(uuid())
  month               DateTime  @db.Date // first of month
  totalFundAmount     Int       @map("total_fund_amount") // cents
  distributionMethod String    @map("distribution_method") // equal | weighted
  perCharityAmounts   Json      @map("per_charity_amounts") // [{ charityId or charity_id, amount }]
  approvedBy          String?   @map("approved_by")
  approvedAt          DateTime? @map("approved_at")
  /** pending | processing | completed */
  payoutStatus        String    @default("pending") @map("payout_status")
  stripeTransferIds   Json?     @map("stripe_transfer_ids")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  approvedByUser User? @relation(fields: [approvedBy], references: [id], onDelete: SetNull)

  @@index([month])
  @@index([approvedBy])
  @@index([payoutStatus])
  @@map("giving_fund_distributions")
}

model ProcessedWebhookEvent {
  id            String   @id @default(uuid())
  stripeEventId String   @unique @map("stripe_event_id")
  eventType     String   @map("event_type")
  processedAt   DateTime @map("processed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([stripeEventId])
  @@index([eventType])
  @@index([processedAt])
  @@map("processed_webhook_events")
}

// ---------------------------------------------------------------------------
// Provider training & certifications
// ---------------------------------------------------------------------------

model Course {
  id                String   @id @default(uuid())
  slug              String   @unique
  title             String
  description       String
  /// "essential" | "specialized"
  category          String
  required          Boolean  @default(false)
  badgeLabel        String   @map("badge_label")
  /// Token mapped to CSS vars in app: primary | secondary | primary-700 | primary-900
  badgeColor        String?  @map("badge_color")
  estimatedMinutes  Int      @map("estimated_minutes")
  totalSlides       Int      @map("total_slides")
  /// Minimum quiz score percentage to pass (e.g. 80)
  passingScore      Int      @map("passing_score")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  slides            CourseSlide[]
  certifications    ProviderCertification[]

  @@index([active])
  @@index([required])
  @@map("courses")
}

model CourseSlide {
  id               String   @id @default(uuid())
  courseId         String   @map("course_id")
  slideNumber      Int      @map("slide_number")
  title            String
  content          String   @db.Text
  imageUrl         String?  @map("image_url")
  /// "lesson" | "quiz"
  slideType        String   @map("slide_type")
  quizQuestion     String?  @map("quiz_question") @db.Text
  /// Array of { text: string, isCorrect: boolean }
  quizOptions      Json?    @map("quiz_options")
  quizExplanation  String?  @map("quiz_explanation") @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, slideNumber])
  @@index([courseId])
  @@map("course_slides")
}

model ProviderCertification {
  id            String    @id @default(uuid())
  providerId    String    @map("provider_id")
  courseId      String    @map("course_id")
  score         Int
  passed        Boolean
  completedAt   DateTime  @map("completed_at")
  /// Human-readable certificate reference when passed; null if failed attempt
  certificateId String?   @unique @map("certificate_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  provider User   @relation(fields: [providerId], references: [id], onDelete: Cascade)
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([providerId, courseId])
  @@index([providerId])
  @@index([courseId])
  @@map("provider_certifications")
}

// ---------------------------------------------------------------------------
// Site-wide images (admin-managed; URLs typically Supabase Storage `site-images`)
// ---------------------------------------------------------------------------

model SiteImage {
  id        String   @id @default(uuid())
  /// Stable id e.g. logo, blog-my-post, provider-andreas-christou
  imageKey  String   @unique @map("key")
  category  String
  label     String
  url       String   @db.Text
  alt       String   @default("")
  width     Int?
  height    Int?
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([category])
  @@map("site_images")
}
